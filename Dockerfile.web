# Multi-stage build for Kanban Web UI + API server
# Shares the same DB contract as the MCP server for a single data directory.

FROM node:22-bookworm-slim AS db-builder
WORKDIR /app
COPY shared/db/package*.json shared/db/
RUN npm ci --prefix shared/db
COPY shared/db shared/db
RUN npm run build --prefix shared/db

FROM node:22-bookworm-slim AS ui-builder
WORKDIR /app
COPY web-ui/package*.json web-ui/
RUN npm ci --prefix web-ui
COPY web-ui web-ui
RUN npm run build --prefix web-ui

FROM node:22-bookworm-slim AS server-builder
WORKDIR /app
COPY shared/db/package*.json shared/db/
RUN npm ci --prefix shared/db
COPY shared/db shared/db
COPY --from=db-builder /app/shared/db/dist shared/db/dist
COPY web-server/package*.json web-server/
RUN npm ci --prefix web-server
COPY web-server web-server
RUN npm run build --prefix web-server

FROM node:22-bookworm-slim
WORKDIR /app
COPY --from=db-builder /app/shared/db shared/db
RUN npm ci --prefix shared/db --omit=dev
COPY --from=server-builder /app/web-server/dist web-server/dist
COPY --from=server-builder /app/web-server/package*.json web-server/
RUN npm ci --prefix web-server --omit=dev
COPY --from=ui-builder /app/web-ui/dist web-ui/dist
ENV MCP_KANBAN_DB_FOLDER_PATH=/data
ENV HOST=0.0.0.0
ENV PORT=8221
VOLUME /data
EXPOSE 8221
CMD ["node", "web-server/dist/index.js"]
